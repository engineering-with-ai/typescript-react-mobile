{
  "name": "typescript-react-mobile",
  "version": "1.0.0-beta",
  "private": true,
  "main": "src/main.ts",
  "scripts": {
    "android": "react-native run-android",
    "build-debug": "cd android && ./gradlew assembleDebug assembleAndroidTest && cd ..",
    "start": "react-native start",
    "start:mock": "RN_MOCKED=true react-native start",
    "depcheck": "depcheck --ignores=@types/*,@babel/*,@react-native/*,@react-native-community/*,@testing-library/*,jest,prettier,typescript,eslint,babel-jest,ts-pattern,winston,yaml,zod,ts-node,tsconfig-paths,react-native-dotenv,metro-config,@tamagui/portal,baseline-browser-mapping,burnt,@tamagui/helpers-icon,react-native-screens,react-native-safe-area-context,react-native-svg",
    "format": "prettier --write src",
    "typecheck": "tsc ; eslint -c eslint-typecheck.config.mjs",
    "audit-src": "eslint -c eslint-security.config.mjs",
    "audit-packages": "npm audit --audit-level=moderate --format=json | grep -qE '\"severity\":\\s*\"(moderate|high|critical)\"' && exit 1 || exit 0",
    "lint": "eslint src --fix",
    "security": "npm run audit-src && npm run audit-packages",
    "checks": "npm run depcheck && npm run format && npm run typecheck && npm run security && npm run lint",
    "unit": "jest",
    "integration": "start-server-and-test start:mock http://localhost:8081 'detox test --configuration android.emu.debug --headless'",
    "test": "npm run unit && npm run integration",
    "cover": "c8 npm run test",
    "review": "claude 'run code-reviewer agent against diff for quality and simplicity'",
    "commit": "npm run checks && npm run cover && npm run review && git add -A && git cz && git push"
  },
  "dependencies": {
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "@tamagui/animations-css": "^1.142.0",
    "@tamagui/core": "^1.140.3",
    "@tamagui/dialog": "^1.142.0",
    "@tamagui/helpers-icon": "^1.142.0",
    "@tamagui/lucide-icons": "^1.142.0",
    "@tamagui/popover": "^1.140.3",
    "@tamagui/portal": "^1.142.0",
    "@tamagui/switch": "^1.142.0",
    "@tamagui/tabs": "^1.142.0",
    "@tamagui/toast": "^1.142.0",
    "@tamagui/tooltip": "^1.142.0",
    "burnt": "^0.13.0",
    "ip-address": "^10.0.1",
    "react": "18.3.1",
    "react-native": "0.76.0",
    "react-native-gifted-charts": "^1.4.70",
    "react-native-safe-area-context": "^4.10.9",
    "react-native-screens": "^3.35.0",
    "react-native-svg": "^15.11.1",
    "ts-pattern": "^5.0.0",
    "yaml": "^2.4.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@eslint/js": "^9.36.0",
    "@react-native-community/cli": "15.0.0-alpha.2",
    "@react-native-community/cli-platform-android": "15.0.0-alpha.2",
    "@react-native/babel-preset": "0.76.0",
    "@react-native/eslint-config": "0.76.0",
    "@react-native/metro-config": "0.76.0",
    "@react-native/typescript-config": "0.76.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.5.2",
    "@types/react": "^18.2.6",
    "@types/react-test-renderer": "^18.0.0",
    "babel-jest": "^29.6.3",
    "babel-plugin-inline-import": "^3.0.0",
    "baseline-browser-mapping": "^2.9.7",
    "c8": "^10.1.3",
    "depcheck": "^1.4.7",
    "detox": "^20.42.0",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsdoc": "^48.11.0",
    "eslint-plugin-no-secrets": "^2.2.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^6.1.0",
    "eslint-plugin-security": "^3.0.1",
    "globals": "^15.15.0",
    "jest": "^29.6.3",
    "prettier": "^3.7.4",
    "react-native-dotenv": "^3.4.11",
    "react-test-renderer": "18.3.1",
    "start-server-and-test": "^2.1.2",
    "ts-jest": "^29.4.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "5.0.4",
    "typescript-eslint": "^8.44.1"
  },
  "engines": {
    "node": ">=24"
  },
  "jest": {
    "preset": "react-native",
    "cache": true,
    "cacheDirectory": ".jest-cache",
    "maxWorkers": "50%",
    "testTimeout": 10000,
    "testMatch": [
      "<rootDir>/src/**/*.test.{js,ts,tsx}"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/src/jest-setup.ts"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!(react-native|@react-native|@react-navigation|react-native-gifted-charts|gifted-charts-core|react-native-svg|react-native-screens|react-native-safe-area-context)/)"
    ]
  },
  "c8": {
    "include": [
      "src/**/*.ts",
      "src/**/*.tsx"
    ],
    "exclude": [
      "**/*.test.ts",
      "**/*.test.tsx",
      "**/*.styles.tsx"
    ],
    "reporter": [
      "text",
      "cobertura"
    ],
    "reports-dir": "coverage",
    "clean": true
  }
}
